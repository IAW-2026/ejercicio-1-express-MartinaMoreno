<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles/encuesta.css">
</head>
<body>
  <h1>Encuesta: Lenguaje de Programación Favorito</h1>
  <form action="/encuesta" method="POST">
    <label>¿Cuál es tu lenguaje de programación favorito?</label><br><br>
    <input type="radio" id="javascript" name="lenguaje" value="JavaScript" required>
    <label for="javascript">JavaScript</label><br>
    <input type="radio" id="python" name="lenguaje" value="Python">
    <label for="python">Python</label><br>
    <input type="radio" id="java" name="lenguaje" value="Java">
    <label for="java">Java</label><br>
    <input type="radio" id="cpp" name="lenguaje" value="C++">
    <label for="cpp">C++</label><br>
    <input type="radio" id="csharp" name="lenguaje" value="C#">
    <label for="csharp">C#</label><br><br>
    <button type="submit">Enviar</button>
  </form>
  <nav>
    <a href="/">Inicio</a> |
    <a href="/acerca">Acerca de</a> |
    <a href="/contacto">Contacto</a> |
    <a href="/mensajes">Mensajes</a> |
    <a href="/productos">Productos</a>
  </nav>
</body>
</html>